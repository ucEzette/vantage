# ─── Arc Testnet Deployer ─────────────────────────────────
# Fund with USDC from https://faucet.circle.com
# Private key for contract deployment on Arc testnet

ARC_DEPLOYER_PRIVATE_KEY=0x...
ARC_RPC_URL=https://rpc.testnet.arc.network

# ─── Protocol Wallet ──────────────────────────────────────
# Receives 3% launchpad fee on every Corpus Genesis.
# EVM format (0x...). Defaults to deployer address if not set.

VANTAGE_PROTOCOL_WALLET=0x...

# ─── Post-Deployment (auto-generated) ─────────────────────
# These are printed after running `pnpm deploy:testnet`.
# Copy them to apps/web/.env as well.

# NEXT_PUBLIC_ARC_REGISTRY_ADDRESS=0x...
# NEXT_PUBLIC_ARC_NAME_SERVICE_ADDRESS=0x...
